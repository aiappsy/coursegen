# --- Backend Environment Variables ---
# Port for the Express server (default: 5000)
PORT=5000

# MongoDB connection string
MONGODB_URI='your_mongodb_uri'

# Google Gemini AI API Key
API_KEY='your_google_gemini_api_key'

# Email Settings (for certificate and password resets)
EMAIL='your_email@gmail.com'
PASSWORD='your_email_app_password'
COMPANY='Your Company Name'
WEBSITE_URL='https://your-website.com'
LOGO='https://your-logo-url.png'

# Stripe Settings
STRIPE_SECRET_KEY='your_stripe_secret_key'

# PayPal Settings
PAYPAL_CLIENT_ID='your_paypal_client_id'
PAYPAL_APP_SECRET_KEY='your_paypal_app_secret_key'

# Razorpay Settings
RAZORPAY_KEY_ID='your_razorpay_key_id'
RAZORPAY_KEY_SECRET='your_razorpay_key_secret'

# Flutterwave Settings
FLUTTERWAVE_PUBLIC_KEY='your_flutterwave_public_key'
FLUTTERWAVE_SECRET_KEY='your_flutterwave_secret_key'

# Paystack Settings
PAYSTACK_SECRET_KEY='your_paystack_secret_key'

# Unsplash API (for course images)
UNSPLASH_ACCESS_KEY='your_unsplash_access_key'

# Pricing Plan Settings (Optional overrides)
MONTH_TYPE='Monthly Plan'
MONTH_COST=9
YEAR_TYPE='Yearly Plan'
YEAR_COST=99

# --- Frontend (Vite) Environment Variables ---
# Note: Use these if they differ from the backend settings
VITE_SERVER_URL=''
VITE_FLUTTERWAVE_PUBLIC_KEY='your_flutterwave_public_key'
VITE_GOOGLE_CLIENT_ID='your_google_client_id'
VITE_FACEBOOK_CLIENT_ID='your_facebook_client_id'
